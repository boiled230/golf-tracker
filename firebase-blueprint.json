{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "A fantasy golf team drafted by a user.",
      "type": "object",
      "properties": {
        "ownerName": { "type": "string", "description": "The name of the team owner." },
        "players": { "type": "array", "items": { "type": "string" }, "description": "List of drafted player names." },
        "traits": { "type": "array", "items": { "type": "string" }, "description": "Personality traits for the owner." },
        "totalEarnings": { "type": "number", "description": "Cumulative winnings." },
        "color": { "type": "string", "description": "Hex color code for the team." }
      },
      "required": ["ownerName", "players"]
    },
    "Leaderboard": {
      "title": "Leaderboard",
      "description": "Cached leaderboard data from ESPN.",
      "type": "object",
      "properties": {
        "tournamentName": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rank": { "type": "string" },
              "name": { "type": "string" },
              "totalScore": { "type": "string" },
              "thru": { "type": "string" },
              "round": { "type": "string" },
              "movement": { "type": "string", "enum": ["rising", "falling", "stable"] }
            }
          }
        }
      },
      "required": ["tournamentName", "players"]
    },
    "WeeklyResult": {
      "title": "Weekly Result",
      "description": "Summary of a completed tournament week.",
      "type": "object",
      "properties": {
        "weekEnding": { "type": "string", "format": "date" },
        "tournamentName": { "type": "string" },
        "winnerTeamId": { "type": "string" },
        "winningGolfer": { "type": "string" },
        "headline": { "type": "string" },
        "subHeadline": { "type": "string" },
        "roast": { "type": "string" },
        "recap": { "type": "object" }
      },
      "required": ["weekEnding", "winnerTeamId"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message in the league chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "gif": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["text", "sender", "senderId"]
    }
  },
  "firestore": {
    "teams": { "schema": "Team", "description": "Collection of fantasy teams." },
    "leaderboards": { "schema": "Leaderboard", "description": "Cached leaderboard states." },
    "results": { "schema": "WeeklyResult", "description": "Historical weekly results." },
    "messages": { "schema": "Message", "description": "League chat messages." }
  }
}
